---
// Contact page — the "Get In Touch" content moved verbatim off the homepage
// (#contact). Keeps the same markup/classes/ids so the global script.js form
// handler (getElementById('contactForm') + Formspree submit) keeps working,
// and the shared .contact-* styles in style.css still apply. useBlogCss loads
// the breadcrumb + .article-page shell.
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Contact — Calma"
  description="Get in touch with Calma — performance lead generation for insurance, home services, and financial verticals. Email info@calma.io or send us a message."
  canonical="https://calma.io/contacts/"
  ogTitle="Contact — Calma"
  ogDescription="Get in touch with Calma — performance lead generation for insurance, home services, and financial verticals."
  useBlogCss={true}
>
  <Header />

  <main id="main-content">
    <div class="article-page">
      <div class="container">

        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">calma.io</a>
          <span class="breadcrumb-sep">/</span>
          <span class="breadcrumb-current">Contact</span>
        </nav>

        <section class="section contact" aria-label="Contact Us">
          <h1 class="section-title">Get In Touch</h1>
          <div class="contact-content">
            <div class="contact-info">
              <h3>Ready to generate quality leads?</h3>
              <p>Let's discuss how we can help grow your business.</p>
              <div class="contact-email">
                <span>Email us: </span>
                <a href="mailto:info@calma.io">info@calma.io</a>
              </div>
              <div class="careers-link">
                <p>Want to work with us? <a
                    href="https://calma-io.notion.site/Open-Vacancies-Calma-Agency-169f120c65df806bba68fc5163bcfa52"
                    target="_blank" class="careers-link-text">Check out our open positions</a></p>
              </div>
            </div>

            <form class="contact-form" id="contactForm" action="https://formspree.io/f/xzzgddjo" method="POST">
              <!-- Formspree honeypot — bots fill it, humans never see it -->
              <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" aria-hidden="true">
              <div class="form-group">
                <input type="text" id="name" name="name" placeholder="Your Name" autocomplete="name" required>
              </div>
              <div class="form-group">
                <input type="email" id="email" name="email" placeholder="Your Email" autocomplete="email" required>
              </div>
              <div class="form-group">
                <input type="text" id="company" name="company" placeholder="Company (optional)" autocomplete="organization">
              </div>
              <div class="form-group">
                <textarea id="message" name="message" placeholder="Tell us about your project" rows="4" required></textarea>
              </div>
              <button type="submit" class="submit-button">Send Message</button>
            </form>
          </div>
        </section>

      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
