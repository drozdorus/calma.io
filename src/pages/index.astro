---
// Homepage — pixel-for-pixel port of the legacy index.html. All 9 sections
// (Hero, About, Verticals, Team, Events, Blog teaser, FAQ, Contact, Footer).
// Loads blog.css + team.css + team.js (homepage uses all three); bodyId="top".
// Footer gets home={true} so its section links render as bare `#anchor`,
// which is what script.js's smooth-scroll (`a[href^="#"]`) matches. The header
// is page-level only now (no section anchors), so it takes no `home` prop.
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SectionNav from '../components/SectionNav.astro';
import IconSprite from '../components/IconSprite.astro';
import ArticleCard from '../components/blog/ArticleCard.astro';
import { events, formatUpcomingDate, formatPastDate } from '../data/events';
import { team, accentFor } from '../data/team';

// FAQ — one array drives both the visible <details> list and the FAQPage
// JSON-LD, so the two can never drift apart again. Answers may contain inline
// HTML (links); the JSON-LD text is the tag-stripped version.
const faqs = [
  {
    q: 'What is Calma?',
    a: 'Calma is a performance lead generation publisher — we generate, verify, and sell leads across our core verticals. Our compliant, high-intent acquisition systems connect lead buyers with qualified prospects through paid channels and AI-driven optimization.',
  },
  {
    q: 'Which verticals do you work with?',
    a: 'We generate leads across six main verticals: auto insurance, home insurance, health insurance, legal services, home improvement, and financial services (HELOC, credit, lending, personal finance).',
  },
  {
    q: 'How does performance-based lead generation work?',
    a: 'We run paid acquisition campaigns across Meta, Google, and TikTok using proprietary AI to optimize bids and creatives in real time. Every lead is verified for intent, authenticity, and compliance before delivery — so buyers only pay for quality.',
  },
  {
    q: 'Do you work with media buyers and marketing partners?',
    a: 'Yes. We work with a curated network of performance marketing partners who run compliant campaigns across paid social, search, and programmatic channels. To discuss a partnership, reach out to <a href="mailto:info@calma.io">info@calma.io</a>.',
  },
  {
    q: 'How do you ensure lead quality and compliance?',
    a: 'Compliance is central to our methodology. All campaigns meet platform policies and industry-specific regulations. Each lead passes multi-layer quality controls — intent verification, deduplication, and compliance checks — before delivery. We operate exclusively in white-hat verticals with consent-based lead collection.',
  },
  {
    q: "What does Calma's pricing model look like?",
    a: 'We operate on a performance basis — pricing is structured around qualified lead delivery, aligned with your downstream conversion goals. We focus on lead quality and long-term partner alignment, not raw volume.',
  },
  {
    q: 'How do I get started?',
    a: 'Send us a message through our <a href="/contacts/">contact page</a> or email <a href="mailto:info@calma.io">info@calma.io</a>. We\'ll discuss your vertical, volume requirements, and how our acquisition system fits your goals.',
  },
];

const faqMainEntity = faqs.map((f) => ({
  '@type': 'Question',
  name: f.q,
  acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]*>/g, '') },
}));

// Events split on the build date: still-running events stay in "upcoming".
const today = new Date().toISOString().slice(0, 10);
const upcomingEvents = events
  .filter((e) => e.end >= today)
  .sort((a, b) => a.start.localeCompare(b.start));
const pastEvents = events
  .filter((e) => e.end < today)
  .sort((a, b) => b.end.localeCompare(a.end));

// JSON-LD Event entries — only events with full schema data (description).
const eventsJsonLd = events
  .filter((e) => e.description)
  .map((e) => ({
    '@type': 'Event',
    name: e.schemaName ?? e.name,
    description: e.description,
    startDate: e.start,
    endDate: e.end,
    eventStatus: e.end < today ? 'https://schema.org/EventPast' : 'https://schema.org/EventScheduled',
    eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
    location: { '@type': 'Place', name: e.location },
    url: e.url,
    organizer: { '@type': 'Organization', name: e.organizer!.name, url: e.organizer!.url },
    offers: {
      '@type': 'Offer',
      url: e.url,
      availability: `https://schema.org/${e.availability ?? 'InStock'}`,
    },
  }));

// Blog teaser — latest three from the collection (ties resolved by `order`).
const latestPosts = (await getCollection('blog'))
  .sort(
    (a, b) =>
      b.data.date.valueOf() - a.data.date.valueOf() || a.data.order - b.data.order
  )
  .slice(0, 3);
---

<BaseLayout
  title="Calma — Performance Lead Generation Agency"
  description="Calma is a performance lead generation publisher specializing in insurance, legal, financial, and home improvement verticals. Compliance-first, AI-optimized lead acquisition."
  canonical="https://calma.io/"
  keywords="lead generation, lead gen agency, performance lead generation, insurance lead generation, auto insurance leads, home insurance leads, health insurance leads, legal leads, financial services leads, home improvement leads, compliance lead generation, AI lead generation, performance marketing agency, calma, calma agency, calma io, calma marketing, calma lead gen"
  ogTitle="Calma — Performance Lead Generation Agency"
  ogDescription="Compliance-first, AI-optimized lead acquisition for insurance, legal, financial, and home improvement verticals."
  ogImage="https://calma.io/img/metaimg.png"
  twitterTitle="Calma — Performance Lead Generation Agency"
  twitterDescription="Compliance-first, AI-optimized lead acquisition for insurance, legal, financial, and home improvement verticals."
  useBlogCss={true}
  useTeamCss={true}
  useTeamScript={true}
  bodyId="top"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "@id": "https://calma.io/#organization",
          "name": "Calma",
          "alternateName": ["Calma Agency", "Calma.io"],
          "url": "https://calma.io",
          "logo": {
            "@type": "ImageObject",
            "url": "https://calma.io/img/logo.svg"
          },
          "image": "https://calma.io/img/metaimg.png",
          "description": "Calma is a performance lead generation publisher specializing in compliance-first, AI-optimized lead acquisition across auto insurance, home insurance, health insurance, legal services, home improvement, and financial services verticals.",
          "email": "info@calma.io",
          "areaServed": "United States",
          "contactPoint": {
            "@type": "ContactPoint",
            "email": "info@calma.io",
            "contactType": "sales"
          },
          "sameAs": [
            "https://www.linkedin.com/company/calma-io/",
            "https://www.crunchbase.com/organization/calma-b99b"
          ],
          "founder": { "@id": "https://calma.io/#founder" },
          "knowsAbout": [
            "Lead Generation",
            "Performance Marketing",
            "Insurance Lead Generation",
            "Compliance Marketing",
            "AI-Driven Marketing",
            "Media Buying",
            "Digital Advertising",
            "Partner Marketing"
          ],
          "hasOfferCatalog": {
            "@type": "OfferCatalog",
            "name": "Lead Generation Services",
            "itemListElement": [
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Auto Insurance Lead Generation" } },
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Home Insurance Lead Generation" } },
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Health Insurance Lead Generation" } },
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Legal Services Lead Generation" } },
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Home Improvement Lead Generation" } },
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Financial Services Lead Generation" } }
            ]
          }
        },
        {
          "@type": "Person",
          "@id": "https://calma.io/#founder",
          "name": "Ruslan Drozdov",
          "jobTitle": "Founder",
          "url": "https://drozdorus.com",
          "sameAs": [
            "https://www.linkedin.com/in/drozdorus/",
            "https://www.crunchbase.com/person/ruslan-drozdov"
          ],
          "worksFor": { "@id": "https://calma.io/#organization" }
        },
        {
          "@type": "WebSite",
          "@id": "https://calma.io/#website",
          "name": "Calma",
          "url": "https://calma.io",
          "publisher": { "@id": "https://calma.io/#organization" },
          "description": "Performance lead generation publisher for insurance, legal, financial, and home improvement verticals"
        },
        ...eventsJsonLd,
        {
          "@type": "FAQPage",
          "@id": "https://calma.io/#faq",
          "mainEntity": faqMainEntity
        }
      ]
    })} />
  </Fragment>

  <!-- SVG icon sprite -->
  <IconSprite />

  <canvas id="waveCanvas"></canvas>

  <Header />

  <main id="main-content">

  <!-- Hero -->
  <section class="hero" aria-label="Hero">
    <div class="container">
      <div class="hero-content">
        <h1 class="hero-title">Keep calm,<br>Calma generates leads</h1>
        <p class="hero-subtitle">Where data meets creativity to fuel lead generation success</p>
        <a href="#about" class="scroll-arrow" aria-label="Scroll down">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="m6 9 6 6 6-6" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- About -->
  <section id="about" class="section about" aria-label="About Calma">
    <div class="container">
      <div class="about-content">
        <h2 class="section-title">About Calma</h2>
        <div class="about-text-section">
          <p class="about-text">
            We run <strong>user acquisition campaigns</strong> across paid social and video — generating, qualifying,
            and selling leads directly to our partners and lead buyers.
          </p>
          <p class="about-secondary">
            We optimize for downstream performance: cost per acquired lead, contact rate, and buyer conversion, not raw
            traffic volume.
          </p>

          <div class="hero-badge">
            <span class="badge-text">AI-Driven Approach</span>
          </div>
        </div>
      </div>

      <!-- Methodology -->
      <div class="methodology">
        <h3 class="methodology-title">Our Methodology</h3>
        <div class="methodology-grid">
          <div class="methodology-item">
            <h4 class="methodology-label">Audience Intelligence</h4>
            <p class="methodology-desc">Proprietary AI identifies optimal prospect profiles and high-intent behavioral
              patterns</p>
          </div>
          <div class="methodology-item">
            <h4 class="methodology-label">Automated Optimization</h4>
            <p class="methodology-desc">Real-time bid management and creative testing across all acquisition channels
            </p>
          </div>
          <div class="methodology-item">
            <h4 class="methodology-label">Lead Verification</h4>
            <p class="methodology-desc">Multi-layer quality controls ensure lead authenticity, compliance, and intent
            </p>
          </div>
        </div>
      </div>

      <!-- Traffic Sources -->
      <div class="traffic-sources">
        <h3 class="traffic-sources-title">Acquisition Channels</h3>
        <p class="traffic-sources-desc">We deploy performance across major acquisition channels with compliance-first
          creative and measurement</p>
        <div class="traffic-sources-grid">
          <div class="traffic-source">
            <div class="traffic-source-logo">
              <img src="/img/meta.svg" alt="Meta">
            </div>
          </div>
          <div class="traffic-source">
            <div class="traffic-source-logo">
              <img src="/img/google.svg" alt="Google Ads">
            </div>
          </div>
          <div class="traffic-source">
            <div class="traffic-source-logo">
              <img src="/img/tt.svg" alt="TikTok Ads">
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Verticals -->
  <section id="verticals" class="section services" aria-label="Our Verticals">
    <div class="container">
      <div class="services-header">
        <h2 class="section-title">What We Do</h2>
        <p class="section-subtitle">We focus on leadgen across high-value verticals</p>
      </div>

      <div class="services-grid">
        <div class="service-card">
          <div class="service-head">
            <div class="service-icon">
              <svg width="18" height="18" aria-hidden="true">
                <use href="#icon-shield" />
              </svg>
            </div>
            <h3 class="service-title">Insurance</h3>
          </div>
          <ul class="service-list">
            <li>Auto</li>
            <li>Home</li>
            <li>Health</li>
          </ul>
        </div>
        <div class="service-card">
          <div class="service-head">
            <div class="service-icon">
              <svg width="18" height="18" aria-hidden="true">
                <use href="#icon-home" />
              </svg>
            </div>
            <h3 class="service-title">Home Services</h3>
          </div>
          <ul class="service-list">
            <li>Roofing</li>
            <li>Solar Panels</li>
            <li>Windows</li>
          </ul>
          <span class="service-more">+ more</span>
        </div>
        <div class="service-card">
          <div class="service-head">
            <div class="service-icon">
              <svg width="18" height="18" aria-hidden="true">
                <use href="#icon-finance" />
              </svg>
            </div>
            <h3 class="service-title">Finance</h3>
          </div>
          <ul class="service-list">
            <li>Loans</li>
            <li>HELOC</li>
            <li>HECM</li>
          </ul>
          <span class="service-more">+ more</span>
        </div>
      </div>

      <div class="approach">
        <p>Each vertical requires specialized knowledge of customer psychology, regulatory requirements, and market
          dynamics. Our systems are built specifically for these verticals</p>
      </div>

      <div class="services-cta">
        <a href="/lead-generation/" class="text-link">Explore lead generation by vertical</a>
      </div>
    </div>
  </section>

  <section id="team" class="section team" aria-label="The Team">
    <div class="container">
      <h2 class="section-title">The Team</h2>
      <p class="section-subtitle">The people behind the leads</p>

      <div class="team-scroller">
        <div class="team-track">
          {team.map((m, i) => (
            <div class="team-card" style={`--card-accent: ${accentFor(i, team.length)}`}>
              <div class="team-avatar-wrap">
                <div class="team-avatar">
                  <img src={`/img/team/${m.img}`} alt={m.alt} />
                </div>
                {(m.website || m.linkedin) && (
                  <div class="team-links">
                    {m.website && (
                      <a href={m.website} class="team-link" target="_blank" rel="noopener" aria-label="Website">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                          stroke-linecap="round" stroke-linejoin="round">
                          <circle cx="12" cy="12" r="10" />
                          <line x1="2" y1="12" x2="22" y2="12" />
                          <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                        </svg>
                      </a>
                    )}
                    {m.linkedin && (
                      <a href={m.linkedin} class="team-link" target="_blank" rel="noopener" aria-label="LinkedIn">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor">
                          <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
                          <rect x="2" y="9" width="4" height="12" />
                          <circle cx="4" cy="4" r="2" />
                        </svg>
                      </a>
                    )}
                  </div>
                )}
              </div>
              <div class="team-info">
                <div class="team-name">{m.name}</div>
                <div class="team-role">{m.role}</div>
              </div>
            </div>
          ))}
          <div class="team-card team-card--more">
            <div class="team-avatar team-avatar--empty">
              <span>more<br>soon</span>
            </div>
            <div class="team-info">
              <div class="team-name">&nbsp;</div>
              <div class="team-role">&nbsp;</div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- Events -->
  <section id="conferences" class="section conferences" aria-label="Industry Events">
    <div class="container">
      <h2 class="section-title">Industry Events</h2>
      <p class="section-subtitle">We attend leading performance marketing and lead generation conferences to connect
        with our demand and technology partners</p>

      <!-- Upcoming Events -->
      <div class="events-section">
        <h3 class="events-section-title">Upcoming Events</h3>
        <div class="upcoming-events-scroller">
          <div class="upcoming-events-track">
            {upcomingEvents.map((e) => (
              <a href={e.url} target="_blank" rel="noopener" class="conference-card">
                <div class="conference-logo-wrapper">
                  {e.logo && <img src={e.logo.src} alt={e.logo.alt} />}
                </div>
                <time class="conference-date" datetime={e.start}>{formatUpcomingDate(e)}</time>
                <h4 class="conference-name">{e.name}</h4>
                <p class="conference-location">{e.location}</p>
                <span class="conference-link">{e.linkLabel}</span>
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Past Events -->
      <div class="past-events-section">
        <h3 class="events-section-title">Past Events</h3>
        <div class="past-events-scroller">
          <div class="past-events-track">
            {pastEvents.map((e) => (
              <div class="past-conference-card">
                <time class="past-conference-date" datetime={e.end.slice(0, 7)}>{formatPastDate(e)}</time>
                <h4 class="past-conference-name">{e.name}</h4>
                <p class="past-conference-location">{e.location}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Blog -->
  <section id="blog" class="section" aria-label="Blog">
    <div class="container">
      <h2 class="section-title">Blog</h2>
      <p class="section-subtitle">Perspectives on performance marketing and lead generation</p>
      <div class="blog-grid">
        {latestPosts.map((post) => <ArticleCard post={post} />)}
      </div>
      <div class="blog-view-all">
        <a href="/blog/" class="text-link">View all articles</a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="section faq" aria-label="Frequently Asked Questions">
    <div class="container">
      <h2 class="section-title">FAQ</h2>
      <p class="section-subtitle">Common questions about working with Calma</p>

      <div class="faq-list">
        {faqs.map((f) => (
          <details class="faq-item">
            <summary>{f.q}<span class="faq-icon" aria-hidden="true">+</span></summary>
            <div class="faq-answer"><p set:html={f.a} /></div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div class="section-divider"></div>

  <!-- CTA band -->
  <section class="section" aria-label="Get in touch">
    <div class="container">
      <div class="home-cta">
        <h2 class="home-cta-heading">Ready to generate leads?</h2>
        <p class="home-cta-text">Tell us about your vertical and volume goals — we'll show you how our acquisition system fits.</p>
        <a href="/contacts/" class="vertical-cta-btn">Get in touch</a>
      </div>
    </div>
  </section>

  </main>

  <SectionNav />

  <Footer home={true} />
</BaseLayout>
