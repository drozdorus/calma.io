---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import IconSprite from '../../components/IconSprite.astro';

// Mirrors the homepage "What We Do" block. A link exists wherever there is a
// dedicated page: sub-niches for insurance (auto, home), the group itself for
// home services and finance.
const groups = [
  {
    icon: 'icon-shield',
    title: 'Insurance',
    href: null,
    items: [
      { label: 'Auto', href: '/lead-generation/auto-insurance/' },
      { label: 'Home', href: '/lead-generation/home-insurance/' },
      { label: 'Health', href: null },
    ],
  },
  {
    icon: 'icon-home',
    title: 'Home Services',
    href: '/lead-generation/home-services/',
    items: [{ label: 'Roofing' }, { label: 'Solar' }, { label: 'Windows' }],
  },
  {
    icon: 'icon-finance',
    title: 'Finance',
    href: '/lead-generation/finance/',
    items: [{ label: 'Loans' }, { label: 'HELOC' }, { label: 'Reverse mortgage' }],
  },
];
---

<BaseLayout
  title="Lead Generation by Vertical — Calma"
  description="The verticals Calma generates, qualifies, and delivers leads for — auto and home insurance, home services, and financial services. Compliance-first performance lead generation."
  canonical="https://calma.io/lead-generation/"
  ogTitle="Lead Generation by Vertical"
  ogDescription="The verticals Calma generates, qualifies, and delivers leads for."
  useBlogCss={true}
>
  <IconSprite />
  <Header />

  <main id="main-content">
    <div class="article-page">
      <div class="container">

        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">calma.io</a>
          <span class="breadcrumb-sep">/</span>
          <span class="breadcrumb-current">Lead Generation</span>
        </nav>

        <header class="vhub-hero">
          <h1 class="section-title">Lead Generation by Vertical</h1>
          <p class="section-subtitle">The verticals we generate, qualify, and deliver leads for</p>
        </header>

        <div class="services-grid vhub-grid">
          {groups.map((g) => (
            <div class="service-card">
              <div class="service-head">
                <div class="service-icon">
                  <svg width="18" height="18" aria-hidden="true"><use href={`#${g.icon}`} /></svg>
                </div>
                {g.href ? (
                  <a class="service-title vhub-grouplink" href={g.href}>{g.title}<span class="vhub-arrow">→</span></a>
                ) : (
                  <h3 class="service-title">{g.title}</h3>
                )}
              </div>
              <ul class="service-list">
                {g.items.map((it) => (
                  <li>
                    {it.href ? (
                      <a class="vhub-itemlink" href={it.href}>{it.label}<span class="vhub-arrow">→</span></a>
                    ) : (
                      it.label
                    )}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>

      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .vhub-hero {
    margin: 1.75rem 0 2.5rem;
    text-align: center;
  }
  /* .service-card defaults to opacity:0 until inside a scroll-observed
     .section.visible on the homepage — force visible on this static page. */
  .vhub-grid :global(.service-card) {
    opacity: 1;
    transform: none;
  }
  .vhub-grouplink {
    text-decoration: none;
    color: var(--text);
    transition: color 0.2s var(--ease);
  }
  .vhub-grouplink:hover {
    color: var(--primary);
  }
  .vhub-itemlink {
    text-decoration: none;
    color: var(--text-secondary);
    transition: color 0.2s var(--ease);
  }
  .vhub-itemlink:hover {
    color: var(--primary);
  }
  .vhub-arrow {
    color: var(--primary);
    font-size: 0.8em;
    margin-left: 0.35em;
  }
</style>
